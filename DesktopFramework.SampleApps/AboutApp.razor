@* Sample app: renders about/system info fetched from the backend API,
   with graceful error + retry handling. *@

<div class="wos-app-pad">
    @if (_result is null)
    {
        <span class="wos-loading"><i class="fa-solid fa-spinner fa-spin"></i> Loading…</span>
    }
    else if (!_result.IsSuccess)
    {
        <ApiError StatusCode="_result.StatusCode" Title="@_result.ErrorTitle"
                  Message="@_result.ErrorMessage" OnRetry="LoadAsync" />
    }
    else
    {
        <h2>@_result.Value!.Title</h2>
        @if (!string.IsNullOrEmpty(_result.Value.Html))
        {
            @((MarkupString)_result.Value.Html)
        }
        else
        {
            <p>@_result.Value.Body</p>
        }
    }
</div>

@code {
    [Inject] private IDesktopContentService Content { get; set; } = default!;

    private ApiResult<ContentDto>? _result;

    protected override async Task OnInitializedAsync()
    {
        if (!RendererInfo.IsInteractive) return;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _result = null;
        StateHasChanged();
        _result = await Content.GetAboutAsync();
    }
}
