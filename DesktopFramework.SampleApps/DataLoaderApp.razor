@* Sample app: loads data from a deliberately slow API endpoint
   (GET /api/content/report, ~2.5s). While it loads, BusyService turns the whole
   desktop cursor into the Windows-style loading cursor. API errors are shown
   in-place with a Retry, never crashing the front end. *@

<div class="wos-app-pad">
    <h2>Data Loader</h2>
    <p>Loads data from a slow API endpoint. While it fetches, the desktop cursor
       turns into the loading cursor.</p>

    <button class="wos-btn" @onclick="LoadAsync" disabled="@_loading">
        <i class="fa-solid fa-cloud-arrow-down"></i> Load data
    </button>

    <div style="margin-top:16px;">
        @if (_loading)
        {
            <span class="wos-loading">
                <i class="fa-solid fa-spinner fa-spin"></i> Loading…
            </span>
        }
        else if (_result is { IsSuccess: false })
        {
            <ApiError StatusCode="_result.StatusCode" Title="@_result.ErrorTitle"
                      Message="@_result.ErrorMessage" OnRetry="LoadAsync" />
        }
        else if (_result?.Value is { } data)
        {
            <h3>@data.Title</h3>
            <p>@data.Body</p>
            <small style="color:var(--wos-text-muted);">Fetched at @data.UpdatedAt?.ToString("HH:mm:ss")</small>
        }
    </div>
</div>

@code {
    [Inject] private IDesktopContentService Content { get; set; } = default!;
    [Inject] private BusyService Busy { get; set; } = default!;

    private bool _loading;
    private ApiResult<ContentDto>? _result;

    private async Task LoadAsync()
    {
        _loading = true;
        _result = null;

        try
        {
            // Begin() shows the busy cursor for the whole desktop until disposed.
            _result = await Busy.RunAsync(() => Content.GetReportAsync());
        }
        finally
        {
            _loading = false;
        }
    }
}
