@implements IAsyncDisposable
@* A single window: chrome + dynamic content + resize handles. JS owns the live
   drag/resize gesture; geometry is committed back to WindowManager on gesture end. *@

<div @ref="_element"
     class="wos-window @(Window.IsActive ? "is-active" : null)"
     style="@StyleString"
     data-wos-maximized="@(Window.IsMaximized ? "true" : "false")"
     data-wos-min-width="@Window.Options.MinSize.Width"
     data-wos-min-height="@Window.Options.MinSize.Height">

    <WindowTitleBar Window="Window" />
    <WindowContent Window="Window" />

    @if (Window.Options.Resizable && !Window.IsMaximized)
    {
        @foreach (var dir in ResizeDirections)
        {
            <div class="wos-resize wos-resize--@dir" data-wos-resize-handle="@dir"></div>
        }
    }
</div>

@code {
    private static readonly string[] ResizeDirections = ["n", "s", "e", "w", "ne", "nw", "se", "sw"];

    [Parameter, EditorRequired] public WindowInstance Window { get; set; } = default!;
    [Inject] private WindowManager Windows { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private ElementReference _element;
    private IJSObjectReference? _module;
    private DotNetObjectReference<AppWindow>? _ref;

    private string StyleString
    {
        get
        {
            // Minimized windows stay rendered (preserving component state) but hidden.
            if (Window.IsMinimized)
                return "display:none;";

            return Window.IsMaximized
                ? $"left:0;top:0;width:100%;height:100%;z-index:{Window.ZIndex};"
                : $"left:{Px(Window.Position.X)};top:{Px(Window.Position.Y)};" +
                  $"width:{Px(Window.Size.Width)};height:{Px(Window.Size.Height)};z-index:{Window.ZIndex};";
        }
    }

    private static string Px(double v) => v.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture) + "px";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./_content/DesktopFramework.Components/js/window-interop.js");
            _ref = DotNetObjectReference.Create(this);
            await _module.InvokeVoidAsync("init", _element, _ref);
        }
    }

    [JSInvokable] public void OnActivate() => Windows.Focus(Window.Id);

    [JSInvokable] public void OnMoveEnd(double x, double y) =>
        Windows.Move(Window.Id, new WindowPosition(x, y));

    [JSInvokable] public void OnResizeEnd(double x, double y, double w, double h) =>
        Windows.Resize(Window.Id, new WindowPosition(x, y), new WindowSize(w, h));

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_module is not null)
            {
                await _module.InvokeVoidAsync("dispose", _element);
                await _module.DisposeAsync();
            }
        }
        catch (JSDisconnectedException) { /* circuit gone — nothing to clean up */ }
        finally
        {
            _ref?.Dispose();
        }
    }
}
