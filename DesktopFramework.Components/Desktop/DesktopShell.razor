@implements IAsyncDisposable
@* Root of the web desktop. Composes the background (icons + windows), the
   start menu, the notification panel and the taskbar; owns theme application
   and layout restore. *@

<div class="wos-shell @(Busy.IsBusy ? "wos-shell--busy" : null)">
    <DesktopBackground />
    <FullscreenButton />
    <StartMenu />
    <NotificationArea />
    <NotificationToasts />
    <Taskbar />
</div>

@code {
    [Inject] private ThemeService Theme { get; set; } = default!;
    [Inject] private WindowPersistenceService Persistence { get; set; } = default!;
    [Inject] private BusyService Busy { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private IJSObjectReference? _module;

    protected override void OnInitialized()
    {
        Theme.Changed += OnThemeChanged;
        Busy.Changed += OnBusyChanged;
    }

    private void OnBusyChanged() => InvokeAsync(StateHasChanged);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _module = await JS.InvokeAsync<IJSObjectReference>(
            "import", "./_content/DesktopFramework.Components/js/window-interop.js");

        await Theme.InitializeAsync();
        await ApplyThemeAsync();
        await Persistence.RestoreAsync();
        StateHasChanged();
    }

    private async void OnThemeChanged()
    {
        await ApplyThemeAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task ApplyThemeAsync()
    {
        if (_module is not null)
            await _module.InvokeVoidAsync("applyTheme", Theme.DataThemeValue);
    }

    public async ValueTask DisposeAsync()
    {
        Theme.Changed -= OnThemeChanged;
        Busy.Changed -= OnBusyChanged;
        try
        {
            if (_module is not null) await _module.DisposeAsync();
        }
        catch (JSDisconnectedException) { }
    }
}
